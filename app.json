{
  "expo": {
    "name": "Nail'd",
    "slug": "nailed-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./client/public/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./client/public/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5e6e0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.nailed.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./client/public/adaptive-icon.png",
        "backgroundColor": "#f5e6e0"
      },
      "package": "com.nailed.app",
      "permissions": [
        "INTERNET",
        "CAMERA"
      ],
      "versionCode": 1
    },
    "web": {
      "favicon": "./client/public/favicon.ico"
    },
    "extra": {
      "eas": {
        "projectId": "dad5b5d5-7965-4919-ab70-9dc067cb1545"
      }
    }
  }
}
